            "config": {
                "endpoint": "/api/data/inverter"
            },
            "cache": {
                "staleTime": 30000,
                "gcTime": 300000,
                "refetchInterval": 30000
            },
            "returnStructure": {
                "dimensions": [
                    "assetId",
                    "assetName",
                    "siteName",
                    "timestamp"
                ],
                "measurements": [
                    "activePower",
                    "reactivePower",
                    "dailyEnergy",
                    "totalEnergy",
                    "efficiency"
                ]
            }
        },
        {
