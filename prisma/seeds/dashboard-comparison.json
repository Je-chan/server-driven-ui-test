    "dataSources": [
        {
            "id": "ds_inverter",
            "type": "timeseries",
            "name": {
                "defaultValue": "\uc778\ubc84\ud130 \ub370\uc774\ud130",
                "i18nValue": {
                    "ko": "\uc778\ubc84\ud130 \ub370\uc774\ud130",
                    "en": "Inverter Data"
